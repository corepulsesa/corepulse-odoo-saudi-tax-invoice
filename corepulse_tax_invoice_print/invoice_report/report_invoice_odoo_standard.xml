<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="report_invoice_document_custom" inherit_id="l10n_gcc_invoice.l10n_gcc_report_invoice_document">
            <!-- Replace address section with custom layout -->
            <xpath expr='//t[@t-set="address"]' position="replace">
                <t t-set="address">
                    <t t-set="country_id_arabic_name" t-value="o.with_context(lang='ar_001').partner_id.country_id.name"/>
                    <div class="mt16" style="text-align:right !important;">
                        <table class="table table-sm" style="font-family: myFont;font-size: 14px; margin:0;padding:0;">
                        <tbody>
                            <tr style="border: 1px solid #fff; margin:0;padding:0;">
                                <td>
                                    <span t-if="o.move_type =='out_invoice'"> Name:</span>
                                    <span t-if="o.move_type =='in_invoice'"> Name:</span>
                                </td>
                                <td style="text-align: center;">
                                    <span t-field="o.partner_id.name"/>
                                </td>
                                <td style="direction: rtl;text-align: right;">
                                    <span t-if="o.move_type =='out_invoice'">الاسم :</span>
                                    <span t-if="o.move_type =='in_invoice'">الاسم :</span>
                                </td>
                            </tr>
                            <tr style="border: 1px solid #fff; margin:0;padding:0;">
                                <td>
                                    <span t-if="o.move_type =='out_invoice'"> Address:</span>
                                    <span t-if="o.move_type =='in_invoice'"> Address:</span>
                                </td>
                                <td style="width: 60%;text-align: center;">
                                    <t t-set="country_id_arabic_name"
                                       t-value="o.with_context(lang='ar_001').partner_id.country_id.name"/>
                                    <span t-field="o.partner_id.city"/>,
                                    <span t-field="o.partner_id.street2"/>,
                                    <span t-field="o.partner_id.street"/>,
                                    <span t-field="o.partner_id.zip"/>,
                                    <span t-esc="country_id_arabic_name"/>
                                </td>
                                <td style="direction: rtl;text-align: right;">
                                    <span t-if="o.move_type =='out_invoice'">العنوان
                                        :
                                    </span>
                                    <span t-if="o.move_type =='in_invoice'">العنوان
                                        :
                                    </span>
                                </td>
                            </tr>

                            <tr t-if="o.partner_id.vat" style="border: 1px solid #fff; margin:0;padding:0;">
                                <td>
                                    <span t-if="o.move_type =='out_invoice'"> VAT Number:</span>
                                    <span t-if="o.move_type =='in_invoice'"> VAT Number:</span>
                                </td>
                                <td style="width: 35%;text-align: center;">
                                    <span t-field="o.partner_id.vat"/>
                                </td>
                                <td style="direction: rtl;text-align: right;">
                                    <span t-if="o.move_type =='out_invoice'">الرقم
                                        الضريبي :
                                    </span>
                                    <span t-if="o.move_type =='in_invoice'">الرقم
                                        الضريبي :
                                    </span>
                                </td>
                            </tr>
                            <tr t-if="o.partner_id.l10n_sa_edi_additional_identification_number" style="border: 1px solid #fff; margin:0;padding:0;">
                                <td>
                                    <span t-if="o.move_type =='out_invoice'"> CR Number:</span>
                                    <span t-if="o.move_type =='in_invoice'"> CR Number:</span>
                                </td>
                                <td style="width: 35%;text-align: center;">
                                    <span t-field="o.partner_id.l10n_sa_edi_additional_identification_number"/>
                                </td>
                                <td style="direction: rtl;text-align: right;">
                                    <span t-if="o.move_type =='out_invoice'">
                                        السجل التجاري :
                                    </span>
                                    <span t-if="o.move_type =='in_invoice'">
                                        السجل التجاري :
                                    </span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                </t>
            </xpath>
        </template>
    </data>
</odoo>